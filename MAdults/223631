      "Voice": "c_2363_1_027_2149"
    },
    {
      "BGM": null,
      "CharaAnimation": 2,
      "Effect": null,
      "Motion": 2,
      "Name": null,
      "Order": 41,
      "SE": null,
      "Serif": "意識が遠のき、やがてそれは彼女の感覚を麻痺させる。",
