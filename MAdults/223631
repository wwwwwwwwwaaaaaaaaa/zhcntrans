    {
      "BGM": null,
      "CharaAnimation": 2,
      "Effect": null,
      "Motion": 2,
      "Name": "オーディン",
      "Order": 46,
      "SE": null,
      "Serif": "んひぃっ！？あ、ぐぅぅ……ナカで……あ、うぐぅ、や、やめ……やめて、いや、いやぁあああああああああああああ！！",
      "StillPath": null,
