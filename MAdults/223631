    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": "村人１",
      "Order": 4,
      "SE": null,
      "Serif": "あれ？さっきのお嬢ちゃんじゃねぇか？どうやってここがわかったんだ？",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": "村人２",
      "Order": 5,
      "SE": null,
      "Serif": "おっと、抵抗するんじゃねぇぜ！この女がどうなってもいいのかよ！",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": null,
      "Order": 6,
      "SE": null,
      "Serif": "ぐったりと横たわるトールに、男たちに抗う力はない。",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": null,
      "Order": 7,
      "SE": null,
      "Serif": "オーディンは後をつけられ、トールから目を離した自分の愚かさを悔いた。",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": "オーディン",
      "Order": 8,
      "SE": null,
      "Serif": "ま、待ってください……。友達は体調が悪いんです……だから、ひどいことはやめてください",
      "StillPath": null,
      "Voice": "c_2363_1_016_2149"
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": "村人１",
      "Order": 9,
      "SE": null,
      "Serif": "あん？じゃあ、取引しようじゃねぇか？何を差し出せばいいかはわかるよなぁ～？",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": "オーディン",
      "Order": 10,
      "SE": null,
      "Serif": "……わかりました。わたしを好きにしてください",
      "StillPath": null,
      "Voice": "c_2363_1_017_2149"
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": "2",
      "Motion": 1,
      "Name": null,
      "Order": 11,
      "SE": null,
      "Serif": "床に押し倒されたオーディンの服を男達が引き裂く。",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": "オーディン",
      "Order": 12,
      "SE": null,
      "Serif": "くぅ……わたしがもっとしっかりしていれば……",
      "StillPath": null,
      "Voice": "c_2363_1_018_2149"
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": "村人１",
      "Order": 13,
      "SE": null,
      "Serif": "ははは！友達のために犠牲になろうって殊勝な心掛けだねー！感激してチンポが勃ってきやがったぜ！",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": null,
      "Order": 14,
      "SE": null,
      "Serif": "オーディンの露わになった秘部に、男がいきり立った肉棒を近付ける。",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": null,
      "Order": 15,
      "SE": null,
      "Serif": "その男の背後から、トールが虚ろな目でオーディンを見つめる。",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": "オーディン",
      "Order": 16,
      "SE": null,
      "Serif": "そういや、お前……俺に触らないでって言ったよな？じゃあ、触らなくていいぜ！ノーハンドフェラってことで口だけでイカせてくれよ！",
      "StillPath": null,
      "Voice": "c_2363_1_019_2149"
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": null,
      "Order": 17,
      "SE": null,
      "Serif": "顔の前の男が、彼女の頭を掴み股間へと近づける。",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": null,
      "Order": 18,
      "SE": null,
      "Serif": "生臭い性器の臭いに、オーディンが眉を顰める。",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": "オーディン",
      "Order": 19,
      "SE": null,
      "Serif": "んぐぅ……！？く、臭い……変なモノ近づけないで……！",
      "StillPath": null,
      "Voice": "c_2363_1_020_2149"
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": "村人２",
      "Order": 20,
      "SE": null,
      "Serif": "こいつ……小さくて細い首してやがるクセにやけに力が強いぜ。おら、ダチの代わりなんだろーが、抵抗すんじゃねえよ！ダチがどうなってもいいのかよ！",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": null,
      "Order": 21,
      "SE": null,
      "Serif": "男たちの仲間がトールのすぐ側でナイフを手に順番を待っている。",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": null,
      "Order": 22,
      "SE": null,
      "Serif": "オーディンは首の力を緩めるしかなかった。",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": "オーディン",
      "Order": 23,
      "SE": null,
      "Serif": "あっ……う、うぅ……。わ、わかりました……すいません……",
      "StillPath": null,
      "Voice": "c_2363_1_021_2149"
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": "村人２",
      "Order": 24,
      "SE": null,
      "Serif": "ぎゃはは！素直な女は嫌いじゃねーぜ！",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": "村人１",
      "Order": 25,
      "SE": null,
      "Serif": "じゃあ、後もつかえてることだし、とっとと始めるか！ま、恨むんなら、ちょっと強いからってチョーシに乗ったバカな自分を恨むんだな！",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": "オーディン",
      "Order": 26,
      "SE": null,
      "Serif": "うぅ……%user_nameさん……！！たすけて……ん、んん～～～～～～～っ！？",
      "StillPath": null,
      "Voice": "c_2363_1_022_2149"
    },
    {
      "BGM": null,
      "CharaAnimation": 1,
      "Effect": null,
      "Motion": 1,
      "Name": null,
      "Order": 27,
      "SE": null,
      "Serif": "彼が助けに来るなどという未来はあるはずもなく、彼女の身体を男たちの欲望が貫いた。",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 2,
      "Effect": null,
      "Motion": 1,
      "Name": "オーディン",
      "Order": 28,
      "SE": null,
      "Serif": "んぐぅっ！？ん、ふぐぅぅぅ……っ！！",
      "StillPath": null,
      "Voice": "c_2363_1_023_2149"
    },
    {
      "BGM": null,
      "CharaAnimation": 2,
      "Effect": null,
      "Motion": 1,
      "Name": null,
      "Order": 29,
      "SE": null,
      "Serif": "膣と口を男根が塞ぎ、抽送を加えてきた。",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 2,
      "Effect": null,
      "Motion": 1,
      "Name": null,
      "Order": 30,
      "SE": null,
      "Serif": "その苛烈な責めにオーディンの身体が軋む。",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 2,
      "Effect": null,
      "Motion": 1,
      "Name": "オーディン",
      "Order": 31,
      "SE": null,
      "Serif": "ぐる、じい……息が……。ん、ぶぅ、ごほっ、はっ……はぐっ……",
      "StillPath": null,
      "Voice": "c_2363_1_024_2149"
    },
    {
      "BGM": null,
      "CharaAnimation": 2,
      "Effect": null,
      "Motion": 1,
      "Name": "村人１",
      "Order": 32,
      "SE": null,
      "Serif": "おい、さっき誰かの名前を言ってたよなぁ？彼氏か、おい？",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 2,
      "Effect": null,
      "Motion": 1,
      "Name": "村人２",
      "Order": 33,
      "SE": null,
      "Serif": "ははは、彼氏もかわいそうな奴だぜ！これからは、俺のチンポしゃぶった口とキスするんだからな！",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 2,
      "Effect": null,
      "Motion": 1,
      "Name": "オーディン",
      "Order": 34,
      "SE": null,
      "Serif": "ち、違います……！%user_nameさんは……そんな関係じゃ……。ん、んぶぅ、喉に……押し込んで……こない、で……",
      "StillPath": null,
      "Voice": "c_2363_1_025_2149"
    },
    {
      "BGM": null,
      "CharaAnimation": 2,
      "Effect": null,
      "Motion": 1,
      "Name": null,
      "Order": 35,
      "SE": null,
      "Serif": "息苦しさにオーディンの小さな身体が身悶える。",
      "StillPath": null,
      "Voice": null
