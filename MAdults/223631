    {
      "BGM": null,
      "CharaAnimation": 2,
      "Effect": null,
      "Motion": 2,
      "Name": "オーディン",
      "Order": 40,
      "SE": null,
      "Serif": "んぐっ、かっ、げぼっ……！？は、はぁっ……ん、んぶっ、んぐぐ～っ！！",
