    {
      "BGM": null,
      "CharaAnimation": 2,
      "Effect": null,
      "Motion": 1,
      "Name": null,
      "Order": 36,
      "SE": null,
      "Serif": "しかし、収縮する筋肉はより男たちを喜ばせるだけだった。",
      "StillPath": null,
      "Voice": null
    },
    {
      "BGM": null,
      "CharaAnimation": 2,
      "Effect": null,
      "Motion": 1,
      "Name": "村人１",
      "Order": 37,
      "SE": null,
      "Serif": "はっ、ぎゅんぎゅん締め付けてくるぜ！ま、彼氏じゃねーなら遠慮はいらねえよな？このまま中出しキメてもよぉーーーっ！！",
      "StillPath": null,
      "Voice": null
