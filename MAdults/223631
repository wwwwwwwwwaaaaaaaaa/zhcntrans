    {
      "BGM": null,
      "CharaAnimation": 2,
      "Effect": null,
      "Motion": 2,
      "Name": "オーディン",
      "Order": 38,
      "SE": null,
      "Serif": "な、中出し……！？いや、いやぁああああ！お願いします……外に出して、外にぃっ！！",
